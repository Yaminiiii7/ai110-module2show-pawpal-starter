        +is_schedule_valid() boolean
    }

    class Scheduler {
        +get_tasks_from_owner(owner) List~Task~
        +build_plan_for_owner(owner, available_minutes) List~Task~
        +add_pet_to_owner(owner, pet) void
        +summarize_tasks(owner) String
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : contains
